# AI Provider
GITTRIBUTOR_AI_PROVIDER=anthropic  # Which AI backend to use: "anthropic" or "openai" (default: anthropic)

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key  # Anthropic API key (use this OR CLAUDE_CODE_OAUTH_TOKEN)
CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_oauth_token  # Anthropic OAuth token alternative to ANTHROPIC_API_KEY

# OpenAI
OPENAI_API_KEY=your_openai_api_key  # OpenAI API key (use this OR OPENAI_OAUTH_TOKEN)
OPENAI_OAUTH_TOKEN=your_openai_oauth_token  # OpenAI OAuth token alternative to OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini  # OpenAI model name (default: gpt-4o-mini)

# GitHub
GITHUB_TOKEN=your_github_personal_access_token  # GitHub personal access token used for PR submission

# Tuning
GITTRIBUTOR_ANALYZER_MAX_TOKENS=700  # Max tokens for analysis generation (positive integer; default: 700)
GITTRIBUTOR_FIX_MAX_TOKENS=1024  # Max tokens for fix generation (positive integer; default: 1024)
GITTRIBUTOR_FIX_MAX_PROMPT_FILE_LINES=90  # Max lines per file included in fix prompt (positive integer; default: 90)
GITTRIBUTOR_ANALYZER_MAX_FILES=3  # Max files analyzer includes per issue (positive integer; default: 3)
GITTRIBUTOR_ANALYZER_MAX_LINES_PER_FILE=250  # Max lines read per file during analysis (positive integer; default: 250)
