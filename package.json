{
  "name": "gittributor",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "gittributor": "src/index.ts"
  },
  "scripts": {
    "gittributor": "bun run src/index.ts",
